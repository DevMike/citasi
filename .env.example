# Province code (8=Barcelona, 28=Madrid, etc.)
PROVINCE=8

# Exact visible text of the tramite option to select
TRAMITE_TEXT=

# Document type: nie, passport, or dni
DOC_TYPE=nie

# Document number (e.g. Y1234567X)
DOC_NUMBER=

# Full name as it appears on the document
FULL_NAME=

# Country of nationality (exact text as shown in dropdown)
COUNTRY=

# Contact phone number
PHONE=

# Contact email
EMAIL=

# Telegram Bot API token (from @BotFather)
TELEGRAM_TOKEN=

# Telegram chat ID to send notifications to
TELEGRAM_CHAT_ID=

# Seconds between checks (default: 60)
CHECK_INTERVAL=60

# Max random jitter in seconds added to interval (default: 15)
CHECK_JITTER=15

# Max number of cycles, 0 = unlimited (default: 0)
MAX_CYCLES=0

# Page operation timeout in seconds (default: 30)
PAGE_TIMEOUT=30

# Save screenshots of each check (default: true)
SAVE_SCREENSHOTS=true

# Directory for screenshots (default: screenshots)
SCREENSHOT_DIR=screenshots
